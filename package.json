{
  "name": "tailadmin template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev > dev.log 2>&1",
    "build": "next build && xcopy .next\\static .next\\standalone\\.next\\static /E /I && xcopy public .next\\standalone\\public /E /I && copy dev.db .next\\standalone\\dev.db",
    "start": "next start > server.log 2>&1",
    "start:standalone": "set NODE_ENV=production&& node .next/standalone/server.js",
    "lint": "eslint"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/interaction": "^6.1.21",
    "@fullcalendar/react": "^6.1.21",
    "@fullcalendar/timegrid": "^6.1.21",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-jvectormap/core": "^1.0.4",
    "@react-jvectormap/world": "^1.1.2",
    "apexcharts": "^5.16.0",
    "flatpickr": "^4.6.13",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-apexcharts": "^2.1.1",
    "react-dom": "19.2.7",
    "react-dropzone": "^17.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/flatpickr": "^3.1.4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^10",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
